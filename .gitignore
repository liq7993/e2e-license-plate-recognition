# Python 缓存与编译文件
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so

# 虚拟环境
venv/
.venv/
env/

# 日志与临时文件
*.log
*.tmp
*.temp
*.swp
*.swo

# 训练中产生的本地大目录 / 中间产物
#   仓库已提交 runs/detect/train/ 作为 YOLOv8 训练证据，用白名单保留
logs/
output/
outputs/
runs/*
!runs/detect/
runs/detect/*
!runs/detect/train/

# 训练中间检查点（仓库已提交的发布权重 models/*.pt|*.onnx|*.pth 不会被波及，
# 因为这里只忽略命名规则明显是中间产物的文件）
*.ckpt
stage*_checkpoint_epoch_*.pth
stage*_best_model.pth

# 训练触发文件
pause_training.txt

# IDE / 编辑器配置
.vscode/
.idea/

# Windows 系统文件
Thumbs.db
Desktop.ini

# Jupyter / TensorBoard
.ipynb_checkpoints/
events.out.tfevents.*
